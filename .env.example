# ===== Database =====
DATABASE_URL=postgresql://gradchoice:gradchoice_dev@localhost:5432/gradchoice

# ===== JWT =====
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Do NOT use the placeholder value. Generate a real secret before running.
SECRET_KEY=REPLACE_ME_WITH_OUTPUT_OF_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== SMTP (optional) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@gradchoice.cn
SMTP_PASSWORD=

# ===== Frontend =====
VITE_API_URL=/api

# ===== Seed =====
TUTOR_CSV_DIR=/mnt/d/Startup projects/cn-grad-units/tutors/
